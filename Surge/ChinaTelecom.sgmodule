#获取登录URL及Cookie
[Script]
{{{禁用脚本}}}GetCTCookie = type=http-response,pattern=^https:\/\/e\.dlife\.cn\/user\/loginMiddle,requires-body=1,max-size=0,script-path=https://raw.githubusercontent.com/mabinglei/Script/main/Surge/JavaScript/getCTCookie.js

[MITM]
hostname = %APPEND% e.dlife.cn
